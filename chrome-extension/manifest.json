{
  "manifest_version": 3,
  "name": "SafeCadence Quick Console",
  "version": "7.1.0",
  "description": "Quick access to your local SafeCadence instance — recent compliance, briefing, and command jobs without leaving the tab you're on.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://*/api/*"
  ],
  "action": {
    "default_title": "SafeCadence",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
